{
  "permissions": {
    "allow": [
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:services6.arcgis.com)",
      "WebFetch(domain:api.open-meteo.com)",
      "WebFetch(domain:epqs.nationalmap.gov)",
      "WebFetch(domain:archive-api.open-meteo.com)",
      "WebFetch(domain:services1.arcgis.com)",
      "WebFetch(domain:services3.arcgis.com)",
      "WebFetch(domain:gis.data.ca.gov)",
      "WebFetch(domain:ssl.arb.ca.gov)",
      "Bash(.venv/bin/python morel_finder.py)",
      "Bash(.venv/bin/python -u morel_finder.py)",
      "WebFetch(domain:lfps.usgs.gov)",
      "WebFetch(domain:www.landfire.gov)",
      "WebFetch(domain:files.pythonhosted.org)",
      "Bash(.venv/bin/python:*)",
      "Bash(git commit:*)",
      "WebFetch(domain:github.com)",
      "Bash(git add:*)",
      "Bash(.venv/bin/pip install:*)",
      "Bash(git push:*)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:edcintl.cr.usgs.gov)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; case \"$f\" in */phase_scoring.py|*/config.py) .venv/bin/python -m utils.validate_field || exit 2;; esac; }",
            "statusMessage": "Validating field reports..."
          }
        ]
      }
    ]
  }
}
